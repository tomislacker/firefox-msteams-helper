{
  "manifest_version": 3,
  "name": "Teams Hotkey Helper",
  "version": "0.0.2",
  "description": "Quick keyboard shortcuts for Microsoft Teams reactions and hand raise",
  "homepage_url": "https://github.com/tomislacker/firefox-msteams-helper",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://teams.microsoft.com/*"],
      "js": ["content.js"]
    }
  ]
}
